{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "payload-wnam",
  "compatibility_date": "2025-08-15",
  "compatibility_flags": [
    // Enable Node.js API
    // see https://developers.cloudflare.com/workers/configuration/compatibility-flags/#nodejs-compatibility-flag
    "nodejs_compat",
    // Allow to fetch URLs in your app
    // see https://developers.cloudflare.com/workers/configuration/compatibility-flags/#global-fetch-strictly-public
    "global_fetch_strictly_public",
  ],
  // Deploy: Cloudflare Pages often runs `pnpm run build` then `pnpm run deploy`. Use `pnpm run deploy:ci` so OpenNext
  // skips a second `next build` (SKIP_NEXT_APP_BUILD / opennext `--skipNextBuild`). Local full builds keep `pnpm run deploy`.
  // Wrangler API error 100312 ("Completion token has already been consumed") is usually transient—retry deployment,
  // avoid two concurrent deploys to the same worker name, and keep `wrangler` current in package.json.
  // Smart Placement: run closer to back-end (e.g. D1/R2) when it reduces latency — not a CLI flag; deploy via opennext/wrangler
  // https://developers.cloudflare.com/workers/configuration/placement/
  "placement": {
    "mode": "smart",
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
  "d1_databases": [
    {
      "binding": "D1",
      "database_id": "f2aac41b-418d-47de-8bb3-edda485b1e2b",
      "database_name": "payload-wnam",
      "remote": true,
    },
  ],
  "services": [
    // The service should match the "name" of your worker
    // {
    //   "binding": "WORKER_SELF_REFERENCE",
    //   "service": "my-app"
    // },
  ],
  // Domain generation (n8n parity): POST /api/sites/generate-domain needs Worker secrets
  // SPACESHIP_API_KEY + SPACESHIP_API_SECRET (and existing OPENAI_API_KEY / OPENROUTER for OpenRouter).
  // Cron triggers require a Worker `scheduled` handler. OpenNext does not emit one yet —
  // use GitHub Actions (`.github/workflows/pipeline-cron.yml` + `pipeline-daily.yml`) calling
  // POST /api/pipeline/tick?execute=1 and POST /api/pipeline/cron-dispatch with `x-internal-token: PAYLOAD_SECRET`.
  // Cloudflare weekdays: 1=Sun … 7=Sat (not Unix 0–6; DOW "0" is invalid). Weekly slots below = Monday UTC.
  // `crons` stays empty until a dedicated cron Worker or OpenNext `scheduled()` exists.
  "triggers": {
    "crons": []
  },
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "payload-wnam","preview_bucket_name": "payload-wnam",
    },
    // Create a R2 binding with the binding name "NEXT_INC_CACHE_R2_BUCKET"
    // {
    //   "binding": "NEXT_INC_CACHE_R2_BUCKET",
    //   "bucket_name": "<BUCKET_NAME>",
    // },
  ],

  // Here's how to configure an additional environment
  // It can be deployed with `CLOUDFLARE_ENV=staging pnpm run deploy`
  // "env": {
  //   "staging": {
  //     "name": "my-app-staging",
  //     "d1_databases": [
  //       {
  //         "binding": "D1",
  //         "database_id": "DATABASE_ID",
  //         "database_name": "my-app-staging",
  //         "remote": true
  //       }
  //     ],
  //     "services": [
  //       // The service should match the "name" of your worker
  //       // {
  //       //   "binding": "WORKER_SELF_REFERENCE",
  //       //   "service": "my-app-staging"
  //       // },
  //     ],
  //     "r2_buckets": [
  //       {
  //         "binding": "R2",
  //         "bucket_name": "my-app-staging"
  //       }
  //       // Create a R2 binding with the binding name "NEXT_INC_CACHE_R2_BUCKET"
  //       // {
  //       //   "binding": "NEXT_INC_CACHE_R2_BUCKET",
  //       //   "bucket_name": "<BUCKET_NAME>",
  //       // },
  //     ]
  //   }
  // }
}
